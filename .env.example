# =====================================================================
# Polyweat - Polymarket Weather/Temperature Trading Bot
# Copy to `.env` and fill in your values. Never commit `.env`.
# =====================================================================

# ---------------------------------------------------------------------
# Polymarket credentials (only required if LIVE_TRADING=true)
# ---------------------------------------------------------------------
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_PROXY_ADDRESS=

# ---------------------------------------------------------------------
# Execution mode
# DRY_RUN=true and LIVE_TRADING=false  -> simulate only, no real orders
# DRY_RUN=false and LIVE_TRADING=true  -> place real orders on CLOB
# Anything else                        -> safe simulation mode
# ---------------------------------------------------------------------
DRY_RUN=true
LIVE_TRADING=false

# ---------------------------------------------------------------------
# Weather provider (Open-Meteo needs no API key)
# ---------------------------------------------------------------------
WEATHER_PROVIDER=open_meteo
WEATHER_API_KEY=

# ---------------------------------------------------------------------
# Scan cadence (seconds)
# ---------------------------------------------------------------------
SCAN_INTERVAL_SECONDS=60
FAST_SCAN_INTERVAL_SECONDS=30

# ---------------------------------------------------------------------
# Entry price band (probability units 0..1)
# ---------------------------------------------------------------------
MIN_ENTRY_PRICE=0.95
MAX_ENTRY_PRICE=0.985

# ---------------------------------------------------------------------
# Resolution time horizons (hours)
# ---------------------------------------------------------------------
MAX_HOURS_TO_RESOLUTION=18
PREFERRED_HOURS_TO_RESOLUTION=12
BEST_HOURS_TO_RESOLUTION=6

# ---------------------------------------------------------------------
# Bot probability thresholds (0..1)
# ---------------------------------------------------------------------
MIN_BOT_PROBABILITY=0.93
PREFERRED_BOT_PROBABILITY=0.95

# ---------------------------------------------------------------------
# Confidence score thresholds (0..1)
# ---------------------------------------------------------------------
MIN_CONFIDENCE_SCORE=0.90
PREFERRED_CONFIDENCE_SCORE=0.95

# ---------------------------------------------------------------------
# Forecast distance from threshold (must be FAR from threshold)
# ---------------------------------------------------------------------
MIN_TEMP_DISTANCE_C=2.0
PREFERRED_TEMP_DISTANCE_C=3.0
MIN_TEMP_DISTANCE_F=3.5
PREFERRED_TEMP_DISTANCE_F=5.0

# ---------------------------------------------------------------------
# Liquidity (USD)
# ---------------------------------------------------------------------
MIN_LIQUIDITY_USD=250
PREFERRED_LIQUIDITY_USD=500

# ---------------------------------------------------------------------
# Spread (percent of mid)
# ---------------------------------------------------------------------
MAX_SPREAD_PERCENT=1.5
PREFERRED_SPREAD_PERCENT=1.0

# ---------------------------------------------------------------------
# Risk management
# ---------------------------------------------------------------------
MAX_POSITION_PER_MARKET_USD=1
MAX_OPEN_POSITIONS=5
MAX_DAILY_LOSS_USD=5

# ---------------------------------------------------------------------
# Passive limit orders
# ---------------------------------------------------------------------
ALLOW_PASSIVE_LIMIT_ORDERS=true
PASSIVE_ORDER_MIN_PRICE=0.95
PASSIVE_ORDER_MAX_PRICE=0.975
PASSIVE_ORDER_EXPIRE_SECONDS=180

# ---------------------------------------------------------------------
# Safety toggles
# ---------------------------------------------------------------------
ALLOW_LONGSHOT=false
ALLOW_EXACT_TEMP_MARKETS=false
ALLOW_AMBIGUOUS_MARKETS=false

# ---------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------
DATA_DIR=./data
LOG_DIR=./logs
DB_PATH=./data/polyweat.db
LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# Endpoints (override if Polymarket changes hosts)
# ---------------------------------------------------------------------
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
OPEN_METEO_BASE=https://api.open-meteo.com/v1
OPEN_METEO_GEOCODE_BASE=https://geocoding-api.open-meteo.com/v1
HTTP_TIMEOUT_SECONDS=15


# ---------------------------------------------------------------------
# Live signing config
# 1 = direct EOA (raw private key signer)
# 2 = proxy / Magic-link wallet (requires POLYMARKET_PROXY_ADDRESS)
# Defaults to 2 to match Polymarket UI users.
# ---------------------------------------------------------------------
POLYMARKET_SIGNATURE_TYPE=2

# ---------------------------------------------------------------------
# Reliability
# ---------------------------------------------------------------------
# Exit (and let systemd Restart=on-failure decide) after this many
# consecutive scan_once failures.
MAX_CONSECUTIVE_SCAN_FAILURES=5
# How long to keep scanned_markets / forecasts / rejected_markets rows.
SCANNED_MARKETS_RETENTION_DAYS=7


# ---------------------------------------------------------------------
# Daily-only trading
# When true (default), the bot trades ONLY markets that resolve TODAY
# in the city's local timezone. Markets resolving tomorrow or later
# are skipped, even if they sit within MAX_HOURS_TO_RESOLUTION.
# Set to false to allow markets up to MAX_HOURS_TO_RESOLUTION away.
# ---------------------------------------------------------------------
RESTRICT_TO_TODAY=true
